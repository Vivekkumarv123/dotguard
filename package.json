{
  "name": "dotguard",
  "version": "1.0.0",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./protect": {
      "import": "./dist/protect.js",
      "require": "./dist/protect.cjs"
    }
  },
  "scripts": {
    "dev": "tsup src/index.ts src/protect.ts --format cjs,esm --watch --dts",
    "build": "tsup src/index.ts src/protect.ts --format cjs,esm --dts --clean --minify"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "tsup": "^8.5.1",
    "typescript": "^6.0.2"
  },
  "keywords": [
    "dotenv",
    "env",
    "validation",
    "security",
    "gitignore",
    "shield",
    "guard",
    "config",
    "zero-dependency",
    "typescript"
  ],
  "author": "Vivek Kumar Verma"
}